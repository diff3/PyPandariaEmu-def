# SMSG_UPDATE_OBJECT - Partial, covers out-of-range + living updates (0x20)
endian: little
header:
data:
    map_id: H
    update_count: I

    loop €update_count to updates:
        update_type: B

        if €update_type == 3:
            out_of_range_count: I
            loop €out_of_range_count to out_of_range:
                guid: packed_guid
        elif €update_type == 0:
            guid: packed_guid
            mask_blocks: B
            mask: €mask_blocks*4's, K
            fields: €mask's, V
            dynamic_mask_blocks: B
        elif €update_type in (1, 2):
            guid: packed_guid
            object_type: B
            bitmask 42
                bit676: bits, 1BI
                has_anim_kits: bits, 1BI
                is_living: bits, 1BI
                bit810: bits, 1BI
                bit_fake0: bits, 1BI
                transport_frames: bits, 22BI
                has_vehicle_data: bits, 1BI
                bit1044: bits, 1BI
                bit_fake1: bits, 1BI
                bit476: bits, 1BI
                has_gameobject_rotation: bits, 1BI
                bit_fake2: bits, 1BI
                bit680: bits, 1BI
                has_attacking_target: bits, 1BI
                has_scene_object_data: bits, 1BI
                bit1064: bits, 1BI
                bit_fake3: bits, 1BI
                bit668: bits, 1BI
                has_transport_position: bits, 1BI
                bit681: bits, 1BI
                has_stationary_position: bits, 1BI

            if €is_living:
                guid1_2_mask: bits, 1BI
                bit140: bits, 1BI
                has_pitch_bit: bits, 1BI
                has_transport_data: bits, 1BI
                bit_fake4: bits, 1BI

                if €has_transport_data:
                    transport_guid_4_mask: bits, 1BI
                    transport_guid_2_mask: bits, 1BI
                    has_transport_time3: bits, 1BI
                    transport_guid_0_mask: bits, 1BI
                    transport_guid_1_mask: bits, 1BI
                    transport_guid_3_mask: bits, 1BI
                    transport_guid_6_mask: bits, 1BI
                    transport_guid_7_mask: bits, 1BI
                    has_transport_time2: bits, 1BI
                    transport_guid_5_mask: bits, 1BI

                has_timestamp_bit: bits, 1BI
                guid1_6_mask: bits, 1BI
                guid1_4_mask: bits, 1BI
                guid1_3_mask: bits, 1BI
                has_orientation_bit: bits, 1BI
                bit160_bit: bits, 1BI
                guid1_5_mask: bits, 1BI
                bits98: bits, 22BI
                has_movement_flags_bit: bits, 1BI
                bits168: bits, 19BI
                has_fall_data: bits, 1BI

                has_pitch = 1 - €has_pitch_bit
                has_timestamp = 1 - €has_timestamp_bit
                has_orientation = 1 - €has_orientation_bit
                bit160 = 1 - €bit160_bit
                has_movement_flags = 1 - €has_movement_flags_bit

                if €has_movement_flags:
                    movement_flags: bits, 30BI

                has_spline_elevation_bit: bits, 1BI
                has_spline_elevation = 1 - €has_spline_elevation_bit
                has_spline_data: bits, 1BI
                bit141: bits, 1BI
                guid1_0_mask: bits, 1BI
                guid1_7_mask: bits, 1BI
                guid1_1_mask: bits, 1BI

                if €has_spline_data:
                    has_full_spline: bits, 1BI
                    if €has_full_spline:
                        has_spline_vertical_accel: bits, 1BI
                        has_spline_start_time: bits, 1BI
                        bit304: bits, 1BI
                        spline_count: bits, 20BI
                        spline_mode: bits, 2BI
                        spline_flags: bits, 25BI
                        if €bit304:
                            bits138: bits, 21BI
                            bits138_pad: bits, 2BI

                has_move_flags_extra_bit: bits, 1BI
                has_move_flags_extra = 1 - €has_move_flags_extra_bit
                if €has_fall_data:
                    has_fall_direction: bits, 1BI
                if €has_move_flags_extra:
                    move_flags_extra: bits, 13BI

            if €has_transport_position:
                go_transport_guid_4_mask: bits, 1BI
                go_transport_guid_1_mask: bits, 1BI
                go_transport_guid_0_mask: bits, 1BI
                has_go_transport_time2: bits, 1BI
                go_transport_guid_6_mask: bits, 1BI
                go_transport_guid_5_mask: bits, 1BI
                go_transport_guid_3_mask: bits, 1BI
                go_transport_guid_2_mask: bits, 1BI
                go_transport_guid_7_mask: bits, 1BI
                has_go_transport_time3: bits, 1BI

            if €bit668:
                bit528: bits, 1BI
                bit600: bits, 1BI
                bit544: bits, 1BI
                bit526: bits, 1BI
                bit552: bits, 1BI
                bit524: bits, 1BI
                bit572: bits, 1BI
                bit525: bits, 1BI
                bit664: bits, 1BI
                bit527: bits, 1BI

                if €bit664:
                    bits288: bits, 20BI

                bit536: bits, 1BI
                bit644: bits, 1BI
                bit560: bits, 1BI

                if €bit644:
                    bits25c: bits, 21BI
                    bits26c: bits, 21BI

            if €has_anim_kits:
                has_anim_kit2_bit: bits, 1BI
                has_anim_kit3_bit: bits, 1BI
                has_anim_kit1_bit: bits, 1BI
                has_anim_kit1 = 1 - €has_anim_kit1_bit
                has_anim_kit2 = 1 - €has_anim_kit2_bit
                has_anim_kit3 = 1 - €has_anim_kit3_bit

            if €has_attacking_target:
                atk_guid_4_mask: bits, 1BI
                atk_guid_6_mask: bits, 1BI
                atk_guid_5_mask: bits, 1BI
                atk_guid_2_mask: bits, 1BI
                atk_guid_0_mask: bits, 1BI
                atk_guid_1_mask: bits, 1BI
                atk_guid_3_mask: bits, 1BI
                atk_guid_7_mask: bits, 1BI

            if €bit1064:
                bits418: bits, 22BI

            if €bit810:
                bits2aa: bits, 7BI

            padding 0

            loop €transport_frames to transport_frames:
                transport_frame: I

            if €is_living:
                if €has_transport_data:
                    if €transport_guid_7_mask:
                        transport_guid_7: B, YI
                    transport_x: f
                    if €has_transport_time3:
                        transport_time3: I
                    transport_o: f
                    transport_y: f
                    if €transport_guid_4_mask:
                        transport_guid_4: B, YI
                    if €transport_guid_1_mask:
                        transport_guid_1: B, YI
                    if €transport_guid_3_mask:
                        transport_guid_3: B, YI
                    transport_z: f
                    if €transport_guid_5_mask:
                        transport_guid_5: B, YI
                    if €has_transport_time2:
                        transport_time2: I
                    if €transport_guid_0_mask:
                        transport_guid_0: B, YI
                    transport_seat: b
                    if €transport_guid_6_mask:
                        transport_guid_6: B, YI
                    if €transport_guid_2_mask:
                        transport_guid_2: B, YI
                    transport_time: I
                    transport_guid: combine transport_guid_mask

                if €guid1_4_mask:
                    guid1_4: B, YI

                if €has_spline_data:
                    if €has_full_spline:
                        spline_time: I
                        spline_duration_mod_next: f
                        spline_duration_mod: f
                        loop €spline_count to spline_points:
                            spline_x: f
                            spline_z: f
                            spline_y: f
                        if €has_spline_start_time:
                            spline_start_time: I
                        spline_type: B
                        if €spline_type == 4:
                            spline_facing_angle: f
                        if €spline_type == 2:
                            spline_facing_x: f
                            spline_facing_y: f
                            spline_facing_z: f
                        if €has_spline_vertical_accel:
                            spline_vertical_accel: f
                        spline_full_time: I
                    spline_pos_x: f
                    spline_pos_z: f
                    spline_id: I
                    spline_pos_y: f

                fly_speed: f

                if €bit160:
                    unk160: I

                if €guid1_2_mask:
                    guid1_2: B, YI

                if €has_fall_data:
                    if €has_fall_direction:
                        jump_sin: f
                        jump_xy_speed: f
                        jump_cos: f
                    fall_time: I
                    jump_z_speed: f

                if €guid1_1_mask:
                    guid1_1: B, YI

                turn_speed: f

                if €has_timestamp:
                    time: I

                swim_speed: f

                if €has_spline_elevation:
                    spline_elevation: f

                if €guid1_7_mask:
                    guid1_7: B, YI

                pitch_speed: f

                loop €bits98 to unk_counter:
                    unk_counter: I

                pos_x: f

                if €has_pitch:
                    pitch: f

                if €has_orientation:
                    orientation: f

                walk_speed: f
                pos_y: f
                fly_back_speed: f

                if €guid1_3_mask:
                    guid1_3: B, YI
                if €guid1_5_mask:
                    guid1_5: B, YI
                if €guid1_6_mask:
                    guid1_6: B, YI
                if €guid1_0_mask:
                    guid1_0: B, YI

                run_back_speed: f
                run_speed: f
                swim_back_speed: f
                pos_z: f

                guid1 = €guid

            if €bit668:
                if €bit664:
                    loop €bits288 to unk_float652:
                        unk_float652_4: f
                        unk_float652_0: f
                        unk_float652_8: f

                if €bit600:
                    unk_float584: f
                    unk_float580: f
                    unk_float596: f
                    unk_float592: f
                    unk_float576: f
                    unk_float588: f

                if €bit644:
                    loop €bits25c to unk_float608:
                        unk_float608_0: f
                        unk_float608_4: f
                    loop €bits26c to unk_float260:
                        unk_float260_0: f
                        unk_float260_1: f
                    unk_float624_0: f
                    unk_float624_4: f

                unk520: I
                if €bit544:
                    unk544: I
                if €bit552:
                    unk548: I
                if €bit536:
                    unk532: I
                if €bit560:
                    unk556: I
                if €bit572:
                    unk_float564: f
                    unk_float568: f

            if €has_transport_position:
                if €has_go_transport_time2:
                    transport_time2_go: I
                transport_go_y: f
                transport_go_seat: b
                transport_go_x: f
                if €go_transport_guid_2_mask:
                    go_transport_guid_2: B, YI
                if €go_transport_guid_4_mask:
                    go_transport_guid_4: B, YI
                if €go_transport_guid_1_mask:
                    go_transport_guid_1: B, YI
                if €has_go_transport_time3:
                    transport_time3_go: I
                transport_time_go: I
                transport_go_o: f
                transport_go_z: f
                if €go_transport_guid_6_mask:
                    go_transport_guid_6: B, YI
                if €go_transport_guid_0_mask:
                    go_transport_guid_0: B, YI
                if €go_transport_guid_5_mask:
                    go_transport_guid_5: B, YI
                if €go_transport_guid_3_mask:
                    go_transport_guid_3: B, YI
                if €go_transport_guid_7_mask:
                    go_transport_guid_7: B, YI
                go_transport_guid: combine go_transport_guid_mask

            if €has_attacking_target:
                if €atk_guid_7_mask:
                    atk_guid_7: B, YI
                if €atk_guid_1_mask:
                    atk_guid_1: B, YI
                if €atk_guid_5_mask:
                    atk_guid_5: B, YI
                if €atk_guid_2_mask:
                    atk_guid_2: B, YI
                if €atk_guid_6_mask:
                    atk_guid_6: B, YI
                if €atk_guid_3_mask:
                    atk_guid_3: B, YI
                if €atk_guid_0_mask:
                    atk_guid_0: B, YI
                if €atk_guid_4_mask:
                    atk_guid_4: B, YI
                attacking_target_guid: combine atk_guid_mask

            if €has_vehicle_data:
                vehicle_id: I
                vehicle_orientation: f

            if €has_stationary_position:
                stationary_y: f
                stationary_z: f
                stationary_orientation: f
                stationary_x: f

            if €bit676:
                unk672: I

            if €has_anim_kits:
                if €has_anim_kit1:
                    anim_kit_1: H
                if €has_anim_kit3:
                    anim_kit_3: H
                if €has_anim_kit2:
                    anim_kit_2: H

            if €bit810:
                unk810_bytes: €bits2aa's

            if €bit476:
                unk472: I

            if €bit1064:
                loop €bits418 to unk1052:
                    unk1052: i

            if €has_gameobject_rotation:
                gameobject_rotation: Q

            if €bit1044:
                unk1040: i

            mask_blocks: B
            mask: €mask_blocks*4's, K
            fields: €mask's, V
            dynamic_mask_blocks: B
            # Samma har: normalt ingen tail.
