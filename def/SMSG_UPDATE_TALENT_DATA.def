# SMSG_UPDATE_TALENT_DATA - Minimal
endian: little
header:
data:
    active_spec_group: B
    spec_group_count: bits, 19BI

    loop €spec_group_count to spec_groups:
        glyph_0: H
        glyph_1: H
        glyph_2: H
        glyph_3: H
        glyph_4: H
        glyph_5: H
        spec_id: I
        talent_count: bits, 23BI
        loop €talent_count to talents:
            talent_id: H
